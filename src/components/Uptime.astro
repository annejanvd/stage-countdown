<div class="flex flex-col items-center justify-center w-full">
    <span class="text-text-secondary uppercase tracking-wider text-sm font-medium mb-4">
        System Status
    </span>
    <div id="uptime-list" class="space-y-3 w-full px-4">
        <div class="text-text-muted text-sm text-center">Checking...</div>
    </div>
</div>

<script>
    interface SiteStatus {
        name: string;
        up: boolean;
        ms: number;
    }

    function renderSites(sites: SiteStatus[]) {
        const list = document.getElementById('uptime-list');
        if (!list) return;
        list.innerHTML = '';
        for (const site of sites) {
            const row = document.createElement('div');
            row.className = 'flex items-center justify-between w-full';

            const name = document.createElement('span');
            name.className = 'text-text-primary font-medium';
            name.textContent = site.name;

            const right = document.createElement('div');
            right.className = 'flex items-center gap-2';

            const ms = document.createElement('span');
            ms.className = `text-sm font-mono ${site.up ? 'text-text-muted' : 'text-red-400'}`;
            ms.textContent = site.up ? `${site.ms}ms` : 'down';

            const badge = document.createElement('span');
            badge.className = `text-xs font-bold uppercase tracking-wider ${site.up ? 'text-emerald-400/80' : 'text-rose-400/80'}`;
            badge.textContent = site.up ? 'online' : 'offline';

            right.append(ms, badge);
            row.append(name, right);
            list.append(row);
        }
    }

    async function updateUptime() {
        try {
            const res = await fetch('/api/uptime');
            const sites: SiteStatus[] = await res.json();
            renderSites(sites);
        } catch {}
    }

    updateUptime();
    setInterval(updateUptime, 60000);
</script>
